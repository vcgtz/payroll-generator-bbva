{
  "name": "payroll-generator-bbva",
  "version": "1.0.0",
  "description": "BBVA Payroll PRN file generator",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dist:win": "electron-builder --win"
  },
  "keywords": [],
  "author": "Vicente Gutierrez",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "papaparse": "^5.4.1"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.vcgtz.payroll-generator-bbva",
    "productName": "Dispersion de Nomina BBVA",
    "files": [
      "src/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": ["es_ES"]
    }
  }
}
